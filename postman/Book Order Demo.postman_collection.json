{
  "info": {
    "_postman_id": "1bb3a658-b971-4c45-88fd-d57c5720e3b9",
    "name": "Book Order Demo",
    "description": "Postman collection for the Book Order Demo microservices project.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('staffPassword')) {",
          "  pm.collectionVariables.set('staffPassword', 'password123');",
          "}",
          "if (!pm.collectionVariables.get('customerPassword')) {",
          "  pm.collectionVariables.set('customerPassword', 'password123');",
          "}"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "staffPassword",
      "value": "password123"
    },
    {
      "key": "customerPassword",
      "value": "password123"
    }
  ],
  "item": [
    {
      "name": "1. Initialize Test Variables",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const suffix = String(Date.now());",
              "pm.collectionVariables.set('runSuffix', suffix);",
              "pm.collectionVariables.set('staffEmail', `staff${suffix}@example.com`);",
              "pm.collectionVariables.set('customerEmail', `customer${suffix}@example.com`);",
              "pm.collectionVariables.set('staffName', 'Staff User');",
              "pm.collectionVariables.set('customerName', 'Customer User');",
              "pm.collectionVariables.set('bookTitle', `Postman Demo Book ${suffix}`);",
              "pm.collectionVariables.set('bookAuthor', 'Demo Author');",
              "pm.collectionVariables.set('bookPrice', '29.99');",
              "pm.collectionVariables.set('bookStock', '10');",
              "pm.collectionVariables.set('orderQuantity', '2');",
              "['staffToken', 'customerToken', 'bookId', 'orderId'].forEach((key) => pm.collectionVariables.unset(key));"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('auth health is available', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{authBaseUrl}}/auth/health",
          "host": [
            "{{authBaseUrl}}"
          ],
          "path": [
            "auth",
            "health"
          ]
        }
      },
      "response": []
    },
    {
      "name": "2. Register Staff",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('staff registration succeeded', function () {",
              "  pm.response.to.have.status(201);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"{{staffName}}\",\n  \"email\": \"{{staffEmail}}\",\n  \"password\": \"{{staffPassword}}\",\n  \"role\": \"staff\"\n}"
        },
        "url": {
          "raw": "{{authBaseUrl}}/auth/register",
          "host": [
            "{{authBaseUrl}}"
          ],
          "path": [
            "auth",
            "register"
          ]
        }
      },
      "response": []
    },
    {
